// MSWD Integrated Services Portal (MISP) - Prisma Schema
// Supabase PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────
//  ENUMS
// ─────────────────────────────────────────────

enum VoterStatus {
  ACTIVE
  INACTIVE
  UNKNOWN
}

enum RejectionCode {
  VOTER_INACTIVE
  INCOMPLETE_DOCS
  NOT_ELIGIBLE
  ORIENTATION_REQUIRED
  FAILED_HOME_VISIT
  OTHER
}

enum TenurialStatus {
  OWNER
  RENTER
  SHARER
  BEDSPACER
}

enum DisburseMethod {
  CASH
  MAKATIZEN_CARD
  GCASH
}

enum PayrollBatchStatus {
  DRAFT
  PENDING_MAC
  PENDING_MSWD
  PENDING_MAYOR
  APPROVED
  DISBURSED
  REJECTED
}

enum BookletType {
  MEDICINE
  GROCERY
  MOVIE
}

enum Role {
  SUPER_ADMIN
  ADMIN
  REGISTERED_USER
  GUEST
}

enum ApplicationStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
  DISBURSED
}

enum BenefitCategory {
  FINANCIAL_ASSISTANCE
  MEDICAL_ASSISTANCE
  SENIOR_CITIZEN
  PWD_ASSISTANCE
}

enum DocumentType {
  VALID_ID
  PROOF_OF_RESIDENCY
  MEDICAL_CERTIFICATE
  PWD_ID
  SENIOR_CITIZEN_ID
  INCOME_CERTIFICATE
  BIRTH_CERTIFICATE
  OTHER
}

enum DocumentStatus {
  PENDING
  VERIFIED
  REJECTED
}

// ─────────────────────────────────────────────
//  USER
// ─────────────────────────────────────────────

model User {
  id                 String    @id @default(uuid())
  supabaseId         String    @unique  // links to auth.users in Supabase
  email              String    @unique
  firstName          String
  lastName           String
  middleName         String?
  contactNumber      String?
  role               Role      @default(REGISTERED_USER)

  // Address fields (used for GIS residency verification)
  houseNo            String?
  street             String?
  barangay           String?
  city               String    @default("Makati City")
  province           String    @default("Metro Manila")
  zipCode            String?
  latitude           Float?
  longitude          Float?
  residencyVerified  Boolean   @default(false)

  // PH Data Privacy Act compliance
  consentGiven       Boolean   @default(false)
  consentDate        DateTime?

  isActive           Boolean   @default(true)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  // Relations
  applications       Application[]
  documents          Document[]
  residencyChecks    ResidencyVerification[]
  notifications      Notification[]

  @@index([role])
  @@index([barangay])
  @@index([residencyVerified])
  @@index([createdAt])
  @@map("users")
}

// ─────────────────────────────────────────────
//  BENEFIT PROGRAM
// ─────────────────────────────────────────────

model BenefitProgram {
  id               String          @id @default(uuid())
  name             String
  category         BenefitCategory
  description      String
  requirements     String[]        // list of required documents
  maxAmount        Float?          // max financial assistance (if applicable)
  isActive         Boolean         @default(true)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  // Relations
  applications     Application[]

  @@map("benefit_programs")
}

// ─────────────────────────────────────────────
//  APPLICATION
// ─────────────────────────────────────────────

model Application {
  id                 String            @id @default(uuid())
  referenceNumber    String            @unique @default(cuid())
  userId             String
  benefitProgramId   String
  status             ApplicationStatus @default(PENDING)

  // Applicant snapshot (denormalized for record integrity)
  applicantName      String
  applicantContact   String?
  applicantBarangay  String?
  applicantAddress   String?

  // Purpose / reason
  purpose            String
  amountRequested    Float?
  amountApproved     Float?
  remarks            String?

  // Staff handling
  reviewedBy         String?          // Admin user ID
  reviewedAt         DateTime?
  approvedAt         DateTime?
  disbursedAt        DateTime?

  // Multi-level approval (Phase 1 additions)
  voterStatus        VoterStatus      @default(UNKNOWN)
  approvalLevel      Int              @default(0)   // 0=MAC, 1=MSWD, 2=Mayor, 3=done
  rejectionCode      RejectionCode?
  orientationAttended Boolean         @default(false)
  homeVisitRequired  Boolean          @default(false)
  homeVisitDate      DateTime?
  homeVisitNotes     String?
  macApprovedAt      DateTime?
  macApprovedBy      String?
  mswdApprovedAt     DateTime?
  mswdApprovedBy     String?
  mayorApprovedAt    DateTime?
  mayorApprovedBy    String?
  disbursementMethod DisburseMethod?
  prpwdEncoded       Boolean          @default(false)

  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  // Relations
  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  benefitProgram     BenefitProgram   @relation(fields: [benefitProgramId], references: [id])
  documents          Document[]
  statusHistory      ApplicationStatusHistory[]
  idIssuances        IdIssuance[]

  @@index([userId])
  @@index([status])
  @@index([referenceNumber])
  @@index([applicantBarangay])
  @@index([benefitProgramId])
  @@index([createdAt])
  @@map("applications")
}

// ─────────────────────────────────────────────
//  APPLICATION STATUS HISTORY (AUDIT LOG)
// ─────────────────────────────────────────────

model ApplicationStatusHistory {
  id            String            @id @default(uuid())
  applicationId String
  fromStatus    ApplicationStatus?
  toStatus      ApplicationStatus
  changedBy     String            // Admin user ID
  remarks       String?
  changedAt     DateTime          @default(now())
  approvalLevel Int?
  rejectionCode RejectionCode?

  application   Application       @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@map("application_status_history")
}

// ─────────────────────────────────────────────
//  DOCUMENT
// ─────────────────────────────────────────────

model Document {
  id              String         @id @default(uuid())
  userId          String
  applicationId   String?
  type            DocumentType
  status          DocumentStatus @default(PENDING)

  fileName        String
  fileUrl         String         // Supabase Storage public/signed URL
  fileSize        Int            // bytes
  mimeType        String

  // Verification
  verifiedBy      String?
  verifiedAt      DateTime?
  rejectionReason String?

  // PH Data Privacy – document expiry tracking
  expiresAt       DateTime?

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  application     Application?   @relation(fields: [applicationId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([applicationId])
  @@index([status])
  @@index([createdAt])
  @@map("documents")
}

// ─────────────────────────────────────────────
//  RESIDENCY VERIFICATION (GIS)
// ─────────────────────────────────────────────

model ResidencyVerification {
  id              String   @id @default(uuid())
  userId          String
  latitude        Float
  longitude       Float
  address         String
  isWithinMakati  Boolean
  verifiedAt      DateTime @default(now())

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("residency_verifications")
}

// ─────────────────────────────────────────────
//  NOTIFICATIONS
// ─────────────────────────────────────────────

enum NotificationType {
  APPLICATION_UPDATE
  ANNOUNCEMENT
  DISASTER_ALERT
}

model Notification {
  id        String           @id @default(uuid())
  userId    String?
  title     String
  message   String
  type      NotificationType @default(ANNOUNCEMENT)
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user      User?            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
}

// ─────────────────────────────────────────────
//  ANNOUNCEMENT (Public-facing)
// ─────────────────────────────────────────────

model Announcement {
  id          String   @id @default(uuid())
  title       String
  content     String
  imageUrl    String?
  isPublished Boolean  @default(false)
  publishedAt DateTime?
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("announcements")
}

// ─────────────────────────────────────────────
//  DISASTER & RELIEF MANAGEMENT
// ─────────────────────────────────────────────

enum DisasterType {
  TYPHOON
  FIRE
  FLOOD
  EARTHQUAKE
  LANDSLIDE
  OTHER
}

enum IncidentStatus {
  ACTIVE
  MONITORING
  RESOLVED
}

model DisasterIncident {
  id          String         @id @default(uuid())
  title       String
  type        DisasterType
  description String?
  barangay    String?        // primarily affected barangay
  status      IncidentStatus @default(ACTIVE)
  reportedAt  DateTime       @default(now())
  resolvedAt  DateTime?
  createdBy   String         // admin user ID

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  evacuationCenters EvacuationCenter[]
  reliefInventory   ReliefInventory[]
  payrollBatches    PayrollBatch[]

  @@index([status])
  @@map("disaster_incidents")
}

model EvacuationCenter {
  id                   String            @id @default(uuid())
  disasterIncidentId   String?
  name                 String
  address              String
  barangay             String
  capacity             Int
  currentHeadcount     Int               @default(0)
  isOpen               Boolean           @default(true)
  latitude             Float?
  longitude            Float?
  contactPerson        String?
  contactNumber        String?

  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  incident             DisasterIncident? @relation(fields: [disasterIncidentId], references: [id], onDelete: SetNull)
  evacuees             Evacuee[]

  @@index([disasterIncidentId])
  @@index([barangay])
  @@map("evacuation_centers")
}

model Evacuee {
  id                   String           @id @default(uuid())
  evacuationCenterId   String
  name                 String
  age                  Int?
  barangay             String?          // evacuee's home barangay
  headCount            Int              @default(1) // total family members
  registeredAt         DateTime         @default(now())

  // DAFAC fields (Phase 1 additions)
  dafacNumber          String?          @unique
  tenurialStatus       TenurialStatus?
  assistanceAmount     Float?
  isSenior             Boolean          @default(false)
  isPwd                Boolean          @default(false)
  isPregnant           Boolean          @default(false)
  disbursed            Boolean          @default(false)
  disbursedAt          DateTime?
  disbursementMethod   DisburseMethod?

  evacuationCenter     EvacuationCenter @relation(fields: [evacuationCenterId], references: [id], onDelete: Cascade)
  payrollItems         PayrollItem[]
  reliefVouchers       ReliefVoucher[]

  @@index([evacuationCenterId])
  @@map("evacuees")
}

model ReliefInventory {
  id                   String            @id @default(uuid())
  disasterIncidentId   String?
  itemName             String
  unit                 String            // e.g., "packs", "kg", "boxes"
  quantityAvailable    Int               @default(0)
  quantityDistributed  Int               @default(0)
  barangay             String?           // target distribution barangay
  notes                String?

  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  incident             DisasterIncident? @relation(fields: [disasterIncidentId], references: [id], onDelete: SetNull)
  reliefVouchers       ReliefVoucher[]

  @@index([disasterIncidentId])
  @@map("relief_inventory")
}

// ─────────────────────────────────────────────
//  DAFAC CONFIG
// ─────────────────────────────────────────────

model DafacConfig {
  id             String         @id @default(uuid())
  tenurialStatus TenurialStatus @unique
  amount         Float
  updatedAt      DateTime       @updatedAt
  updatedBy      String?

  @@map("dafac_config")
}

// ─────────────────────────────────────────────
//  PAYROLL BATCHES & ITEMS
// ─────────────────────────────────────────────

model PayrollBatch {
  id               String             @id @default(uuid())
  incidentId       String?
  batchNumber      String             @unique
  status           PayrollBatchStatus @default(DRAFT)
  totalAmount      Float              @default(0)
  rejectionReason  String?
  macApprovedAt    DateTime?
  macApprovedBy    String?
  mswdApprovedAt   DateTime?
  mswdApprovedBy   String?
  mayorApprovedAt  DateTime?
  mayorApprovedBy  String?
  disbursedAt      DateTime?
  createdBy        String
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  incident         DisasterIncident?  @relation(fields: [incidentId], references: [id], onDelete: SetNull)
  items            PayrollItem[]

  @@index([incidentId])
  @@map("payroll_batches")
}

model PayrollItem {
  id             String        @id @default(uuid())
  batchId        String
  evacueeId      String
  amount         Float
  disburseMethod DisburseMethod @default(CASH)
  disbursedAt    DateTime?
  createdAt      DateTime      @default(now())

  batch          PayrollBatch  @relation(fields: [batchId], references: [id], onDelete: Cascade)
  evacuee        Evacuee       @relation(fields: [evacueeId], references: [id], onDelete: Cascade)

  @@unique([batchId, evacueeId])
  @@index([batchId])
  @@index([evacueeId])
  @@map("payroll_items")
}

// ─────────────────────────────────────────────
//  RELIEF VOUCHERS
// ─────────────────────────────────────────────

model ReliefVoucher {
  id           String         @id @default(uuid())
  voucherCode  String         @unique
  evacueeId    String
  inventoryId  String
  quantity     Int            @default(1)
  redeemed     Boolean        @default(false)
  redeemedAt   DateTime?
  redeemedBy   String?
  issuedAt     DateTime       @default(now())
  issuedBy     String

  evacuee      Evacuee        @relation(fields: [evacueeId], references: [id], onDelete: Cascade)
  inventory    ReliefInventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)

  @@index([evacueeId])
  @@index([voucherCode])
  @@map("relief_vouchers")
}

// ─────────────────────────────────────────────
//  AUDIT PHOTOS
// ─────────────────────────────────────────────

model AuditPhoto {
  id          String   @id @default(uuid())
  entityType  String   // "APPLICATION" | "DISBURSEMENT" | "DISTRIBUTION"
  entityId    String
  fileUrl     String
  latitude    Float?
  longitude   Float?
  takenAt     DateTime @default(now())
  uploadedBy  String

  @@index([entityType, entityId])
  @@map("audit_photos")
}

// ─────────────────────────────────────────────
//  ID / BOOKLET ISSUANCES
// ─────────────────────────────────────────────

model IdIssuance {
  id            String      @id @default(uuid())
  applicationId String
  userId        String
  bookletType   BookletType
  bookletNumber String?
  claimDate     DateTime?
  signatureUrl  String?
  issuedBy      String
  createdAt     DateTime    @default(now())

  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@map("id_issuances")
}
